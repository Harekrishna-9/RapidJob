{
  "rules": {
    "posts": {
      ".read": true,
      ".write": "auth != null"
    },
    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'Super Admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'Super Admin')"
      }
    },
    "notifications": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'Super Admin'"
    },
    "userNotifications": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'Super Admin'"
      }
    },
    "accountDeleteRequests": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'Super Admin')",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "visitors": {
      ".read": true,
      ".write": true
    }
  }
}